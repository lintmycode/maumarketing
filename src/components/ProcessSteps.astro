---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;

const steps = [
  {
    number: t('process.step1.number'),
    title: t('process.step1.title'),
    body: t('process.step1.body'),
  },
  {
    number: t('process.step2.number'),
    title: t('process.step2.title'),
    body: t('process.step2.body'),
  },
  {
    number: t('process.step3.number'),
    title: t('process.step3.title'),
    body: t('process.step3.body'),
  },
  {
    number: t('process.step4.number'),
    title: t('process.step4.title'),
    body: t('process.step4.body'),
  },
];
---

<section class="section">
  <div class="container">
    <h2 class="section-heading">{t('process.heading')}</h2>
    <div class="process-grid">
      {steps.map((step) => (
        <div class="process-step">
          <div class="process-step__number">{step.number}</div>
          <h3 class="process-step__title">{step.title}</h3>
          <p class="process-step__body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
