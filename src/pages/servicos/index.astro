---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABlock from '../../components/CTABlock.astro';
import { useTranslations } from '../../i18n/index';

const lang = 'pt';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('services-page.title')}
  description={t('services-page.description')}
  lang={lang}
  alternateLangUrl="/en/services/"
>
  <div class="page-hero">
    <div class="container">
      <h1>{t('services-page.heading')}</h1>
      <p>{t('services-page.subheading')}</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <p style="font-size: 1.0625rem; color: var(--mau-muted); max-width: 540px; margin-bottom: 3rem;">
        {t('services-page.intro')}
      </p>
      <div class="service-grid">
        <ServiceCard
          title={t('service.landing.title')}
          problem={t('service.landing.problem')}
          outcome={t('service.landing.outcome')}
          href={t('service.landing.href')}
          ctaLabel={t('service.cta')}
        />
        <ServiceCard
          title={t('service.local.title')}
          problem={t('service.local.problem')}
          outcome={t('service.local.outcome')}
          href={t('service.local.href')}
          ctaLabel={t('service.cta')}
        />
        <ServiceCard
          title={t('service.crm.title')}
          problem={t('service.crm.problem')}
          outcome={t('service.crm.outcome')}
          href={t('service.crm.href')}
          ctaLabel={t('service.cta')}
        />
      </div>
    </div>
  </section>

  <CTABlock
    heading={t('cta.default.heading')}
    body={t('cta.default.body')}
    buttonLabel={t('cta.default.button')}
    buttonHref="/contacto"
  />
</BaseLayout>
