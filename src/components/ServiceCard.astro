---
interface Props {
  title: string;
  problem: string;
  outcome: string;
  href: string;
  ctaLabel: string;
}

const { title, problem, outcome, href, ctaLabel } = Astro.props;
---

<article class="service-card">
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__problem">{problem}</p>
  <p class="service-card__outcome">{outcome}</p>
  <a href={href} class="service-card__cta">{ctaLabel}</a>
</article>
