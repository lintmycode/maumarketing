---
interface Props {
  heading: string;
  body: string;
  buttonLabel: string;
  buttonHref: string;
}

const { heading, body, buttonLabel, buttonHref } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="cta-block">
      <h2>{heading}</h2>
      <p>{body}</p>
      <a href={buttonHref} class="btn btn--ghost">{buttonLabel}</a>
    </div>
  </div>
</section>
