---
import '@picocss/pico/css/pico.min.css';
import '../styles/global.scss';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, type Lang } from '../i18n/index';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  /** URL of the equivalent page in the other language */
  alternateLangUrl: string;
}

const { title, description, lang, alternateLangUrl } = Astro.props;
const t = useTranslations(lang);
const canonicalUrl = new URL(Astro.url.pathname, 'https://maumarketing.pt').href;
const altLang = lang === 'pt' ? 'en' : 'pt';
const alternateFull = new URL(alternateLangUrl, 'https://maumarketing.pt').href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Alternate language -->
    <link rel="alternate" hreflang={altLang} href={alternateFull} />
    <link rel="alternate" hreflang="x-default" href="https://maumarketing.pt/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_PT' : 'en_GB'} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Prevent Pico's dark mode from kicking in — we only ship light -->
    <meta name="color-scheme" content="light" />
  </head>
  <body>
    <Header lang={lang} alternateLangUrl={alternateLangUrl} t={t} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} t={t} />
  </body>
</html>
